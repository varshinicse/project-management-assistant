# Backend configuration variables
# Please replace the following placeholders with your own keys

# MongoDB connection string (e.g., mongodb+srv://user:pass@cluster.mongodb.net/dbname)
MONGODB_URI=mongodb://localhost:27017/pm_ai_assistant

# Your secret OpenAI API key
OPENAI_API_KEY=your-openai-api-key-here

# Secret key for JWT token hashing (can be any random string)
SECRET_KEY=yoursecretkeyforjwt
